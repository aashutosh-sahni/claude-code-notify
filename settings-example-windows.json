{
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"~/.claude-code-notify/windows/hooks/notify-permission.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"~/.claude-code-notify/windows/hooks/notify-stop.ps1\""
          }
        ]
      }
    ]
  }
}
